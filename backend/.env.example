PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/crypto_portfolio
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
CORS_ORIGIN=http://localhost:5173

# Optional: seed script (npm run seed:admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123

# Optional CoinGecko (default public API URL)
# COINGECKO_API_URL=https://api.coingecko.com/api/v3
# Free/demo tier: register at coingecko.com and set demo API key to avoid rate limits / 429
# COINGECKO_API_KEY=
